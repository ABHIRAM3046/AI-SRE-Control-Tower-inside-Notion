# ===== Notion =====
NOTION_API_KEY=secret_xxx
NOTION_DATABASE_ID=your_database_id

# Property names in your Notion Incidents database
NOTION_PROP_SERVICE_NAME=Service Name
NOTION_PROP_STATUS=Status
NOTION_PROP_STATUS_TYPE=select  # status | select
NOTION_PROP_ERROR_LOGS=Error Logs
NOTION_PROP_SEVERITY=Severity
NOTION_PROP_INCIDENT_TIMELINE=Incident Timeline
NOTION_PROP_AI_ANALYSIS=AI Analysis
NOTION_PROP_RECOMMENDED_FIX=Recommended Fix
NOTION_PROP_DEPLOYMENT_TRIGGER=Deployment Trigger
NOTION_PROP_DEPLOYMENT_TRIGGER_TYPE=checkbox  # rich_text | checkbox
NOTION_PROP_INCIDENT_SUMMARY=Incident Summary

# Only process incidents whose status matches this value (optional)
NOTION_TARGET_STATUS=Open

# ===== AI =====
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ===== Automation =====
AUTOMATION_ENABLED=true
AUTOMATION_BACKEND=github  # github | kubernetes | none

# GitHub Actions backend
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_WORKFLOW_FILE=redeploy.yml
GITHUB_REF=main
GITHUB_TOKEN=ghp_xxx

# Kubernetes backend
KUBE_NAMESPACE=default
KUBE_DEPLOYMENT_PREFIX=

# Poll mode
POLL_SECONDS=30
